// FlowChat — Prisma schema
// Prisma 7 uses the modern `prisma-client` generator (TypeScript, ESM).
// The client is generated into ../generated/prisma and imported via "@/generated/prisma/client".

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Application user, mirrored from Clerk via the user.* webhooks.
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
